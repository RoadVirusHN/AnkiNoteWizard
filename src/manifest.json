{
    "manifest_version": 3,
    "name": "Anki Card Wizard",
    "version": "1.0",
    "description": "Add Anki card from your web page.",
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "js": ["content.js"],
        "matches": ["<all_urls>"]
      }
    ],
    "action" : {
      "default_title": "Click to open Anki Card Wizard"
    },
    "side_panel": {
      "default_path": "index.html"
    },
    "permissions": ["storage", "sidePanel", "activeTab", "scripting", "tabs" ],
    "icons":{
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
  